---
import Container from "./ui/Container.astro";
import BentoCard from "./ui/BentoCard.astro";
import BentoGrid from "./BentoGrid.astro";
import { GlowCards } from "./interactive/GlowCards";

interface Props {
    id?: string;
    class?: string;
}

const { id, class: className } = Astro.props;
---

<section id={id} class:list={["py-24", className]}>
    <Container>
        <!-- Section Header -->
        <div class="text-center mb-16">
            <p
                class="font-mono text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4"
            >
                Platform
            </p>
            <h2
                class="text-3xl sm:text-4xl lg:text-5xl font-medium tracking-tight text-white text-balance"
            >
                Built for scale<br class="hidden sm:block" />
                and freedom
            </h2>
        </div>

        <GlowCards client:load className="relative">
            <BentoGrid>
                <!-- Open Source -->
                <BentoCard
                    data-glow-card
                    class="lg:col-span-4"
                    eyebrow="Freedom"
                    title="Own your infrastructure"
                    description="Self-hosted, no vendor lock-in, community-driven. Full control over your data and deployment."
                    dark
                    fade={["bottom"]}
                >
                    <div slot="graphic" class="absolute inset-0 px-6 py-9">
                        <div class="w-full h-full">
                            <!-- GitHub-style code block -->
                            <div
                                class="bg-[#09090b] rounded-xl p-4 ring-1 ring-white/10 w-full h-full flex flex-col justify-center"
                            >
                                <div class="flex items-center gap-2 mb-3">
                                    <div
                                        class="w-3 h-3 rounded-full bg-red-500/60"
                                    >
                                    </div>
                                    <div
                                        class="w-3 h-3 rounded-full bg-yellow-500/60"
                                    >
                                    </div>
                                    <div
                                        class="w-3 h-3 rounded-full bg-green-500/60"
                                    >
                                    </div>
                                    <span class="ml-2 text-xs text-white/40"
                                        >terminal</span
                                    >
                                </div>
                                <code class="text-sm font-mono">
                                    <span class="text-green-400">$</span>
                                    <span class="text-white/80">
                                        git clone</span
                                    >
                                    <span class="text-violet-400">
                                        lunogram/platform</span
                                    >
                                </code>
                                <div class="mt-2">
                                    <code class="text-sm font-mono">
                                        <span class="text-green-400">$</span>
                                        <span class="text-white/80">
                                            docker compose up</span
                                        >
                                    </code>
                                </div>
                                <div class="mt-3 pt-3 border-t border-white/10">
                                    <div class="flex items-center gap-2">
                                        <svg
                                            class="w-4 h-4 text-green-400"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                        <span class="text-xs text-white/60"
                                            >Ready in seconds</span
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </BentoCard>

                <!-- Enterprise Ready -->
                <div data-glow-card class="relative lg:col-span-2 h-full">
                    <div
                        class="absolute -top-2 -right-2 px-2 py-0.5 bg-violet-500 text-white text-[10px] font-bold uppercase tracking-wide rounded-full z-10"
                    >
                        Coming Soon
                    </div>
                    <BentoCard
                        class="h-full"
                        eyebrow="Security"
                        title="SSO & RBAC included"
                        description="SAML/OpenID, role-based access, multi-project architecture."
                        dark
                        fade={["bottom"]}
                    >
                        <div
                            slot="graphic"
                            class="absolute inset-0 flex items-center justify-center p-6"
                        >
                            <div class="space-y-3 w-full">
                                <div
                                    class="flex items-center gap-3 bg-white/5 px-3 py-2.5 rounded-lg ring-1 ring-white/10"
                                >
                                    <div
                                        class="w-8 h-8 bg-violet-500/20 rounded-lg flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-4 h-4 text-violet-400"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span class="text-white text-xs font-medium"
                                        >SSO</span
                                    >
                                    <svg
                                        class="w-4 h-4 text-green-400 ml-auto"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                                <div
                                    class="flex items-center gap-3 bg-white/5 px-3 py-2.5 rounded-lg ring-1 ring-white/10"
                                >
                                    <div
                                        class="w-8 h-8 bg-blue-500/20 rounded-lg flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-4 h-4 text-blue-400"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span class="text-white text-xs font-medium"
                                        >RBAC</span
                                    >
                                    <svg
                                        class="w-4 h-4 text-green-400 ml-auto"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                                <div
                                    class="flex items-center gap-3 bg-white/5 px-3 py-2.5 rounded-lg ring-1 ring-white/10"
                                >
                                    <div
                                        class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center"
                                    >
                                        <svg
                                            class="w-4 h-4 text-amber-400"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"
                                            ></path>
                                        </svg>
                                    </div>
                                    <span class="text-white text-xs font-medium"
                                        >Multi-Project</span
                                    >
                                    <svg
                                        class="w-4 h-4 text-green-400 ml-auto"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </BentoCard>
                </div>

                <!-- Campaigns -->
                <BentoCard
                    data-glow-card
                    class="lg:col-span-2"
                    eyebrow="Templates"
                    title="Multi-locale campaigns"
                    description="A/B testing, timezone-aware delivery, and delivery tracking."
                    dark
                    fade={["bottom"]}
                >
                    <div
                        slot="graphic"
                        class="absolute inset-0 flex items-center justify-center p-6"
                    >
                        <div class="space-y-2 w-full" id="locale-animation">
                            <!-- Language tabs -->
                            <div class="flex gap-1.5 mb-3">
                                <div
                                    class="locale-tab locale-tab-en px-3 py-1.5 text-xs font-medium rounded-lg ring-1 transition-all duration-300 bg-violet-500/20 text-violet-400 ring-violet-500/30"
                                >
                                    EN
                                </div>
                                <div
                                    class="locale-tab locale-tab-es px-3 py-1.5 text-xs font-medium rounded-lg ring-1 transition-all duration-300 bg-white/5 text-white/50 ring-white/10"
                                >
                                    ES
                                </div>
                                <div
                                    class="locale-tab locale-tab-fr px-3 py-1.5 text-xs font-medium rounded-lg ring-1 transition-all duration-300 bg-white/5 text-white/50 ring-white/10"
                                >
                                    FR
                                </div>
                                <div
                                    class="locale-tab locale-tab-de px-3 py-1.5 text-xs font-medium rounded-lg ring-1 transition-all duration-300 bg-white/5 text-white/50 ring-white/10"
                                >
                                    DE
                                </div>
                            </div>
                            <!-- Campaign preview -->
                            <div
                                class="bg-white/5 rounded-lg p-3 ring-1 ring-white/10"
                            >
                                <div class="flex items-center gap-2 mb-2">
                                    <svg
                                        class="w-4 h-4 text-blue-400"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                        ></path>
                                    </svg>
                                    <span
                                        class="locale-title text-white text-xs font-medium"
                                        >Welcome Email</span
                                    >
                                </div>
                                <div
                                    class="locale-preview text-[10px] text-white/40 truncate"
                                >
                                    Welcome to our platform! Get started...
                                </div>
                            </div>
                            <!-- Stats -->
                            <div class="flex gap-2 mt-2">
                                <div
                                    class="flex-1 bg-white/5 rounded-lg px-2 py-1.5 text-center ring-1 ring-white/10"
                                >
                                    <div
                                        class="locale-delivered text-xs font-semibold text-green-400"
                                    >
                                        98.2%
                                    </div>
                                    <div class="text-[9px] text-white/40">
                                        Delivered
                                    </div>
                                </div>
                                <div
                                    class="flex-1 bg-white/5 rounded-lg px-2 py-1.5 text-center ring-1 ring-white/10"
                                >
                                    <div
                                        class="locale-opened text-xs font-semibold text-blue-400"
                                    >
                                        42.5%
                                    </div>
                                    <div class="text-[9px] text-white/40">
                                        Opened
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </BentoCard>

                <!-- Analytics -->
                <div data-glow-card class="relative lg:col-span-4 h-full">
                    <div
                        class="absolute -top-2 -right-2 px-2 py-0.5 bg-violet-500 text-white text-[10px] font-bold uppercase tracking-wide rounded-full z-10"
                    >
                        Coming Soon
                    </div>
                    <BentoCard
                        class="h-full"
                        eyebrow="Insights"
                        title="Track every interaction"
                        description="Delivery tracking, user events, journey progression, and comprehensive analytics."
                        dark
                        fade={["bottom"]}
                    >
                        <div
                            slot="graphic"
                            class="absolute inset-0 flex items-center justify-center p-8"
                        >
                            <div class="w-full max-w-md">
                                <!-- Mini chart visualization -->
                                <div class="flex items-end gap-1 h-20 mb-4">
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 45%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 60%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 35%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 80%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 65%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 55%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/40 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/70 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 90%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/40 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/70 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 75%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-400 hover:shadow-[0_0_16px_rgba(139,92,246,0.7)]"
                                        style="height: 100%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/60 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/80 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 85%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/40 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/70 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 70%"
                                    >
                                    </div>
                                    <div
                                        class="chart-bar flex-1 bg-violet-500/30 rounded-t-sm transition-all duration-200 cursor-pointer hover:bg-violet-500/60 hover:shadow-[0_0_12px_rgba(139,92,246,0.5)]"
                                        style="height: 50%"
                                    >
                                    </div>
                                </div>
                                <!-- Metric cards -->
                                <div class="grid grid-cols-3 gap-3">
                                    <div
                                        class="bg-white/5 rounded-lg p-3 text-center ring-1 ring-white/10"
                                    >
                                        <div
                                            class="text-lg font-semibold text-white"
                                        >
                                            12.4k
                                        </div>
                                        <div class="text-[10px] text-white/50">
                                            Events Today
                                        </div>
                                    </div>
                                    <div
                                        class="bg-white/5 rounded-lg p-3 text-center ring-1 ring-white/10"
                                    >
                                        <div
                                            class="text-lg font-semibold text-green-400"
                                        >
                                            94.8%
                                        </div>
                                        <div class="text-[10px] text-white/50">
                                            Delivery Rate
                                        </div>
                                    </div>
                                    <div
                                        class="bg-white/5 rounded-lg p-3 text-center ring-1 ring-white/10"
                                    >
                                        <div
                                            class="text-lg font-semibold text-blue-400"
                                        >
                                            2,847
                                        </div>
                                        <div class="text-[10px] text-white/50">
                                            Active Users
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </BentoCard>
                </div>
            </BentoGrid>
        </GlowCards>
    </Container>
</section>

<script>
    import { animate } from "animejs";

    function initLocaleAnimation() {
        const container = document.getElementById("locale-animation");
        if (!container) return;

        // Check for reduced motion preference
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
            return;

        const locales = ["en", "es", "fr", "de"];
        const content = {
            en: {
                title: "Welcome Email",
                preview: "Welcome to our platform! Get started...",
                delivered: "98.2%",
                opened: "42.5%",
            },
            es: {
                title: "Correo de Bienvenida",
                preview: "¡Bienvenido a nuestra plataforma! Comienza...",
                delivered: "97.8%",
                opened: "38.2%",
            },
            fr: {
                title: "Email de Bienvenue",
                preview: "Bienvenue sur notre plateforme! Commencez...",
                delivered: "99.1%",
                opened: "45.7%",
            },
            de: {
                title: "Willkommens-E-Mail",
                preview: "Willkommen auf unserer Plattform! Starten...",
                delivered: "98.5%",
                opened: "41.3%",
            },
        };

        const tabs = locales.map((l) =>
            container.querySelector(`.locale-tab-${l}`),
        );
        const titleEl = container.querySelector(".locale-title");
        const previewEl = container.querySelector(".locale-preview");
        const deliveredEl = container.querySelector(".locale-delivered");
        const openedEl = container.querySelector(".locale-opened");

        let currentIndex = 0;

        function switchLocale() {
            const prevIndex = currentIndex;
            currentIndex = (currentIndex + 1) % locales.length;

            const prevTab = tabs[prevIndex];
            const nextTab = tabs[currentIndex];
            const locale = locales[currentIndex];

            // Animate out previous tab
            if (prevTab) {
                prevTab.classList.remove(
                    "bg-violet-500/20",
                    "text-violet-400",
                    "ring-violet-500/30",
                );
                prevTab.classList.add(
                    "bg-white/5",
                    "text-white/50",
                    "ring-white/10",
                );
            }

            // Animate in next tab
            if (nextTab) {
                nextTab.classList.remove(
                    "bg-white/5",
                    "text-white/50",
                    "ring-white/10",
                );
                nextTab.classList.add(
                    "bg-violet-500/20",
                    "text-violet-400",
                    "ring-violet-500/30",
                );
            }

            // Fade out content, change, fade in
            if (titleEl && previewEl && deliveredEl && openedEl) {
                animate([titleEl, previewEl, deliveredEl, openedEl], {
                    opacity: [1, 0],
                    duration: 150,
                    ease: "outQuad",
                    onComplete: () => {
                        titleEl.textContent = content[locale].title;
                        previewEl.textContent = content[locale].preview;
                        deliveredEl.textContent = content[locale].delivered;
                        openedEl.textContent = content[locale].opened;
                        animate([titleEl, previewEl, deliveredEl, openedEl], {
                            opacity: [0, 1],
                            duration: 150,
                            ease: "inQuad",
                        });
                    },
                });
            }
        }

        // Start the animation loop
        setInterval(switchLocale, 2500);
    }

    // Initialize when DOM is ready
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLocaleAnimation);
    } else {
        initLocaleAnimation();
    }
</script>

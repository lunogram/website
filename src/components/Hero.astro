---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import JourneyAnimation from './interactive/JourneyAnimation';
---

<section class="relative">
  <Container class="relative pt-24 lg:pt-28">
    <!-- Hero content -->
    <div class="py-12 sm:py-16 md:py-20 text-center max-w-4xl mx-auto">
      <!-- Headline -->
      <h1 class="font-display text-4xl/[0.95] font-medium tracking-tight text-balance text-white sm:text-5xl/[0.9] md:text-6xl/[0.9]">
        Turning Customers
        <br class="hidden sm:block" />
        into Relationships
      </h1>
      
      <!-- Subheadline -->
      <p class="mt-8 max-w-2xl mx-auto text-xl/7 font-medium text-white/75 sm:text-2xl/8">
        Onboard, activate, and retain customers across every channel. Proudly built in the EU.
      </p>
      
      <!-- CTA Buttons -->
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <Button variant="primary" size="lg" href="https://accounts.lunogram.com">
          Get Started
        </Button>
        <Button variant="secondary" size="lg" href="https://github.com/lunogram/platform">
          View on GitHub
        </Button>
      </div>
    </div>
    
    <!-- Journey Animation with gradient behind -->
    <div class="relative pb-6 sm:pb-8 overflow-hidden">
      <div class="relative max-w-6xl mx-auto">
        <!-- Main gradient effect behind the animation -->
        <div class="absolute inset-0 sm:-top-20 sm:-bottom-20 sm:-left-20 sm:-right-20 flex items-center justify-center pointer-events-none">
          <div 
            class="w-full h-full max-w-3xl max-h-[500px] rounded-full blur-[100px] opacity-50"
            style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.4) 0%, rgba(96, 165, 250, 0.3) 40%, rgba(244, 114, 182, 0.3) 70%, rgba(167, 139, 250, 0.4) 100%);"
          ></div>
        </div>
        
        <!-- Journey Animation Component - lazy loaded when visible -->
        <JourneyAnimation client:visible />
      </div>
    </div>
  </Container>
</section>

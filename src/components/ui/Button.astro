---
import { clsx } from 'clsx';

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

const { 
  variant = 'primary', 
  size = 'md', 
  href, 
  class: className,
  type = 'button',
  disabled = false,
  ...attrs 
} = Astro.props;

const isLink = Boolean(href);

const baseClasses = [
  'inline-flex items-center justify-center gap-2',
  'font-medium whitespace-nowrap',
  'transition-all duration-200',
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[#09090b]',
  'disabled:pointer-events-none disabled:opacity-50',
];

const variantClasses = {
  primary: [
    'bg-white text-gray-950',
    'rounded-full',
    'shadow-md',
    'hover:bg-gray-100',
    'focus-visible:ring-white',
  ],
  secondary: [
    'bg-white/10 text-white',
    'rounded-full',
    'ring-1 ring-white/15',
    'shadow-[inset_0_0_2px_1px_rgba(255,255,255,0.1)]',
    'hover:bg-white/15',
    'focus-visible:ring-white/30',
  ],
  ghost: [
    'bg-transparent text-white',
    'rounded-lg',
    'hover:bg-white/10',
    'focus-visible:ring-white/20',
  ],
};

const sizeClasses = {
  sm: 'h-8 px-4 text-sm',
  md: 'h-10 px-6 text-sm',
  lg: 'h-12 px-8 text-base',
};

const classes = clsx(
  baseClasses,
  variantClasses[variant],
  sizeClasses[size],
  className,
);
---

{isLink ? (
  <a href={href} class={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class={classes} {...attrs}>
    <slot />
  </button>
)}

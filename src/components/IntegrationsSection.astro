---
import Container from './ui/Container.astro';
import Heading from './ui/Heading.astro';
import Subheading from './ui/Subheading.astro';
import { GlowCards } from './interactive/GlowCards';

interface Props {
  id?: string;
  class?: string;
}

const { id, class: className } = Astro.props;

const integrations = [
  {
    name: 'Resend',
    channel: 'Email',
    description: 'Modern email API for developers',
    color: 'blue',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>`,
  },
  {
    name: 'SendGrid',
    channel: 'Email',
    description: 'Reliable email delivery at scale',
    color: 'blue',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>`,
  },
  {
    name: 'Twilio',
    channel: 'SMS & Voice',
    description: 'Communication APIs for messaging',
    color: 'red',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>`,
  },
  {
    name: 'Push (APN/FCM)',
    channel: 'Push Notifications',
    description: 'Mobile notifications for iOS & Android',
    color: 'violet',
    featured: false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
    </svg>`,
  },
];

// Color mappings for Tailwind classes
const colorClasses = {
  blue: {
    bg: 'bg-blue-500/10',
    ring: 'ring-blue-500/20',
    icon: 'bg-blue-500',
    text: 'text-blue-400',
  },
  violet: {
    bg: 'bg-violet-500/10',
    ring: 'ring-violet-500/20',
    icon: 'bg-violet-500',
    text: 'text-violet-400',
  },
  red: {
    bg: 'bg-red-500/10',
    ring: 'ring-red-500/20',
    icon: 'bg-red-500',
    text: 'text-red-400',
  },
} as const;
---

<section id={id} class:list={['py-24', className]}>
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-16">
      <Subheading class="mb-4">Integrations</Subheading>
      <Heading as="h2" class="text-3xl sm:text-4xl lg:text-5xl">
        Bring your own<br class="hidden sm:block" />
        providers
      </Heading>
      <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">
        Lunogram connects to the email, SMS, and push providers you already use. 
        Swap providers without changing a single line of your engagement logic.
      </p>
    </div>

    <!-- Mobile: Summary Card -->
    <div class="sm:hidden max-w-md mx-auto">
      <div class="relative rounded-2xl p-6 bg-gradient-to-br from-white/10 to-white/5 ring-1 ring-white/20">
        <div class="flex items-center gap-4 mb-4">
          <div class="flex -space-x-2">
            <div class="w-10 h-10 rounded-lg bg-zinc-900 flex items-center justify-center">
              <div class="w-full h-full rounded-lg bg-blue-500/20 ring-1 ring-blue-500/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-zinc-900 flex items-center justify-center">
              <div class="w-full h-full rounded-lg bg-red-500/20 ring-1 ring-red-500/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-zinc-900 flex items-center justify-center">
              <div class="w-full h-full rounded-lg bg-violet-500/20 ring-1 ring-violet-500/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                </svg>
              </div>
            </div>
            <div class="w-10 h-10 rounded-lg bg-zinc-900 flex items-center justify-center">
              <div class="w-full h-full rounded-lg bg-amber-500/20 ring-1 ring-amber-500/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
        <h3 class="text-white font-semibold text-lg mb-2">Email, SMS, Push & more</h3>
        <p class="text-sm text-white/60">
          Connect with providers like Resend, Twilio, SendGrid, and push notifications. 
          Swap providers without changing your engagement logic.
        </p>
      </div>
    </div>

    <!-- Desktop: Integration Cards Grid -->
    <GlowCards client:load className="hidden sm:grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
      {integrations.map((integration) => {
        const colors = colorClasses[integration.color as keyof typeof colorClasses];
        return (
          <div 
            data-glow-card
            class="group relative rounded-2xl p-6 transition-all duration-300 bg-white/5 ring-1 ring-white/10 hover:ring-white/20 hover:bg-white/[0.07]">
            {/* Icon */}
            <div class:list={[
              'w-12 h-12 rounded-xl flex items-center justify-center mb-4',
              colors.bg,
              `ring-1 ${colors.ring}`,
            ]}>
              <div class:list={[colors.text]} set:html={integration.icon} />
            </div>
            
            {/* Content */}
            <h3 class="text-white font-semibold mb-1">{integration.name}</h3>
            <p class:list={['text-xs font-medium mb-2', colors.text]}>{integration.channel}</p>
            <p class="text-sm text-white/60">{integration.description}</p>
          </div>
        );
      })}
    </GlowCards>

    <!-- Coming Soon Note -->
    <p class="text-center text-sm text-white/40 mt-8">
      Need a different provider? Build custom integrations with the <a href="https://github.com/lunogram" class="text-violet-400 hover:text-violet-300 transition-colors">WASM plugin SDK</a>.
    </p>
  </Container>
</section>

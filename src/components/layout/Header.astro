---
const { pathname } = Astro.url;
const isOnBlog = pathname === "/blog" || pathname === "/blog/" || pathname.startsWith("/blog/");
const isOnFeatures = pathname === "/features" || pathname === "/features/";
const isOnUseCases = pathname.startsWith("/use-cases");
---

<header class="fixed top-0 left-0 right-0 z-50 pt-4 px-4">
    <!-- Centered pill navigation container -->
    <nav
        class="group/nav relative mx-auto max-w-4xl flex items-center justify-between h-16 px-6 rounded-full backdrop-blur-xl border border-white/15 bg-gradient-to-b from-white/10 to-white/5 shadow-[0_0_20px_-5px_rgba(139,92,246,0.15),inset_0_1px_0_0_rgba(255,255,255,0.1)]"
    >
        <!-- Glow effect -->
        <div
            class="absolute inset-0 rounded-full bg-gradient-to-r from-violet-500/10 via-purple-500/5 to-pink-500/10 blur-xl opacity-40 -z-10"
        >
        </div>
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
            <svg
                class="h-8 w-8 text-white"
                viewBox="0 0 32 32"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <circle
                    cx="16"
                    cy="16"
                    r="14"
                    stroke="currentColor"
                    stroke-width="2"></circle>
                <circle cx="16" cy="16" r="6" fill="currentColor"></circle>
            </svg>
            <span class="text-lg font-semibold text-white">Lunogram</span>
        </a>

        <!-- Right side: Features + Use Cases + Blog + GitHub icon + Get Started (Desktop) -->
        <div class="hidden lg:flex items-center gap-6">
            <a
                href="/features"
                class:list={[
                    "text-[15px] font-medium transition-colors",
                    isOnFeatures ? "text-white" : "text-white/60 hover:text-white",
                ]}
            >
                Features
            </a>
            <a
                href="/use-cases"
                class:list={[
                    "text-[15px] font-medium transition-colors",
                    isOnUseCases ? "text-white" : "text-white/60 hover:text-white",
                ]}
            >
                Use Cases
            </a>
            <a
                href="/blog"
                class:list={[
                    "text-[15px] font-medium transition-colors",
                    isOnBlog ? "text-white" : "text-white/60 hover:text-white",
                ]}
            >
                Blog
            </a>
            <a
                href="https://github.com/lunogram/platform"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 p-2 text-white/70 hover:text-white transition-colors"
                aria-label="View on GitHub"
            >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path
                        fill-rule="evenodd"
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
            <a
                href="https://accounts.lunogram.com"
                class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-violet-600 to-purple-600 rounded-full hover:from-violet-500 hover:to-purple-500 transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40"
            >
                Get Started
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            type="button"
            class="lg:hidden p-2 text-white/60 hover:text-white transition-colors"
            aria-label="Open menu"
            data-mobile-menu-button
        >
            <svg
                class="w-5 h-5 menu-icon-open"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                class="w-5 h-5 menu-icon-close hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu Backdrop -->
    <div
        class="lg:hidden fixed inset-x-0 top-24 bottom-0 bg-black/70 backdrop-blur-md z-30 opacity-0 pointer-events-none transition-opacity duration-300"
        data-mobile-menu-backdrop
    >
    </div>

    <!-- Mobile Menu -->
    <div
        class="lg:hidden fixed inset-x-4 top-24 z-40 rounded-2xl border border-white/15 bg-gradient-to-b from-white/12 to-white/5 shadow-[0_8px_32px_-8px_rgba(139,92,246,0.3),inset_0_1px_0_0_rgba(255,255,255,0.1)] backdrop-blur-2xl opacity-0 pointer-events-none translate-y-[-10px] transition-all duration-300 ease-out"
        data-mobile-menu
    >
        <!-- Glow effect for menu -->
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-violet-500/10 via-transparent to-pink-500/10 opacity-60 pointer-events-none"></div>
        
        <nav class="relative py-4 px-2">
            <!-- Navigation Links -->
            <ul class="space-y-1">
                <li class="mobile-menu-item" style="--item-index: 0;">
                    <a
                        href="/"
                        class:list={[
                            "group flex items-center gap-4 px-4 py-3.5 rounded-xl transition-all duration-200",
                            pathname === "/" 
                                ? "bg-white/10 text-white" 
                                : "text-white/70 hover:bg-white/5 hover:text-white",
                        ]}
                    >
                        <span class:list={[
                            "flex items-center justify-center w-10 h-10 rounded-lg transition-all duration-200",
                            pathname === "/" 
                                ? "bg-gradient-to-br from-violet-500/30 to-purple-500/30 text-white shadow-lg shadow-violet-500/20" 
                                : "bg-white/5 text-white/60 group-hover:bg-white/10 group-hover:text-white/80",
                        ]}>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                            </svg>
                        </span>
                        <div class="flex flex-col">
                            <span class="text-[15px] font-medium">Home</span>
                            <span class="text-xs text-white/40">Back to homepage</span>
                        </div>
                        {pathname === "/" && (
                            <span class="ml-auto w-1.5 h-1.5 rounded-full bg-violet-400 shadow-lg shadow-violet-400/50"></span>
                        )}
                    </a>
                </li>
                <li class="mobile-menu-item" style="--item-index: 1;">
                    <a
                        href="/features"
                        class:list={[
                            "group flex items-center gap-4 px-4 py-3.5 rounded-xl transition-all duration-200",
                            isOnFeatures 
                                ? "bg-white/10 text-white" 
                                : "text-white/70 hover:bg-white/5 hover:text-white",
                        ]}
                    >
                        <span class:list={[
                            "flex items-center justify-center w-10 h-10 rounded-lg transition-all duration-200",
                            isOnFeatures 
                                ? "bg-gradient-to-br from-violet-500/30 to-purple-500/30 text-white shadow-lg shadow-violet-500/20" 
                                : "bg-white/5 text-white/60 group-hover:bg-white/10 group-hover:text-white/80",
                        ]}>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                            </svg>
                        </span>
                        <div class="flex flex-col">
                            <span class="text-[15px] font-medium">Features</span>
                            <span class="text-xs text-white/40">Explore capabilities</span>
                        </div>
                        {isOnFeatures && (
                            <span class="ml-auto w-1.5 h-1.5 rounded-full bg-violet-400 shadow-lg shadow-violet-400/50"></span>
                        )}
                    </a>
                </li>
                <li class="mobile-menu-item" style="--item-index: 2;">
                    <a
                        href="/use-cases"
                        class:list={[
                            "group flex items-center gap-4 px-4 py-3.5 rounded-xl transition-all duration-200",
                            isOnUseCases 
                                ? "bg-white/10 text-white" 
                                : "text-white/70 hover:bg-white/5 hover:text-white",
                        ]}
                    >
                        <span class:list={[
                            "flex items-center justify-center w-10 h-10 rounded-lg transition-all duration-200",
                            isOnUseCases 
                                ? "bg-gradient-to-br from-violet-500/30 to-purple-500/30 text-white shadow-lg shadow-violet-500/20" 
                                : "bg-white/5 text-white/60 group-hover:bg-white/10 group-hover:text-white/80",
                        ]}>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                            </svg>
                        </span>
                        <div class="flex flex-col">
                            <span class="text-[15px] font-medium">Use Cases</span>
                            <span class="text-xs text-white/40">See what's possible</span>
                        </div>
                        {isOnUseCases && (
                            <span class="ml-auto w-1.5 h-1.5 rounded-full bg-violet-400 shadow-lg shadow-violet-400/50"></span>
                        )}
                    </a>
                </li>
                <li class="mobile-menu-item" style="--item-index: 3;">
                    <a
                        href="/blog"
                        class:list={[
                            "group flex items-center gap-4 px-4 py-3.5 rounded-xl transition-all duration-200",
                            isOnBlog 
                                ? "bg-white/10 text-white" 
                                : "text-white/70 hover:bg-white/5 hover:text-white",
                        ]}
                    >
                        <span class:list={[
                            "flex items-center justify-center w-10 h-10 rounded-lg transition-all duration-200",
                            isOnBlog 
                                ? "bg-gradient-to-br from-violet-500/30 to-purple-500/30 text-white shadow-lg shadow-violet-500/20" 
                                : "bg-white/5 text-white/60 group-hover:bg-white/10 group-hover:text-white/80",
                        ]}>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                            </svg>
                        </span>
                        <div class="flex flex-col">
                            <span class="text-[15px] font-medium">Blog</span>
                            <span class="text-xs text-white/40">Read our latest posts</span>
                        </div>
                        {isOnBlog && (
                            <span class="ml-auto w-1.5 h-1.5 rounded-full bg-violet-400 shadow-lg shadow-violet-400/50"></span>
                        )}
                    </a>
                </li>
            </ul>

            <!-- Divider -->
            <div class="my-3 mx-4 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

            <!-- External Links -->
            <div class="mobile-menu-item" style="--item-index: 4;">
                <a
                    href="https://github.com/lunogram/platform"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-4 px-4 py-3.5 rounded-xl text-white/70 hover:bg-white/5 hover:text-white transition-all duration-200"
                >
                    <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 text-white/60 group-hover:bg-white/10 group-hover:text-white/80 transition-all duration-200">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                fill-rule="evenodd"
                                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </span>
                    <div class="flex flex-col">
                        <span class="text-[15px] font-medium">GitHub</span>
                        <span class="text-xs text-white/40">View source code</span>
                    </div>
                    <svg class="ml-auto w-4 h-4 text-white/30 group-hover:text-white/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </a>
            </div>

            <!-- Divider -->
            <div class="my-3 mx-4 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

            <!-- Waitlist CTA -->
            <div class="mobile-menu-item px-4 pb-2" style="--item-index: 5;">
                <a
                    href="https://accounts.lunogram.com"
                    class="flex items-center justify-center gap-2 w-full py-3.5 text-[15px] font-medium text-white bg-gradient-to-r from-violet-600 to-purple-600 rounded-xl hover:from-violet-500 hover:to-purple-500 transition-all duration-200 shadow-lg shadow-violet-500/25"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    Get Started
                </a>
            </div>
        </nav>
    </div>
</header>

<style>
    /* Staggered animation for menu items */
    .mobile-menu-item {
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity 0.3s ease-out, transform 0.3s ease-out;
        transition-delay: calc(var(--item-index) * 50ms + 100ms);
    }
    
    [data-mobile-menu].is-open .mobile-menu-item {
        opacity: 1;
        transform: translateY(0);
    }
    
    /* Closing animation - faster and reverse order */
    [data-mobile-menu].is-closing .mobile-menu-item {
        opacity: 0;
        transform: translateY(-8px);
        transition-delay: calc((5 - var(--item-index)) * 30ms);
    }
</style>

<script>
    const menuButton = document.querySelector("[data-mobile-menu-button]");
    const mobileMenu = document.querySelector("[data-mobile-menu]");
    const mobileMenuBackdrop = document.querySelector(
        "[data-mobile-menu-backdrop]",
    );
    const menuIconOpen = document.querySelector(".menu-icon-open");
    const menuIconClose = document.querySelector(".menu-icon-close");

    if (
        menuButton &&
        mobileMenu &&
        mobileMenuBackdrop &&
        menuIconOpen &&
        menuIconClose
    ) {
        let isAnimating = false;
        
        const closeMenu = () => {
            if (isAnimating) return;
            isAnimating = true;
            
            // Start closing animation
            mobileMenu.classList.add("is-closing");
            mobileMenu.classList.remove("is-open");
            
            // Animate backdrop
            mobileMenuBackdrop.classList.remove("opacity-100");
            mobileMenuBackdrop.classList.add("opacity-0");
            
            // Animate menu container
            mobileMenu.classList.remove("opacity-100", "translate-y-0");
            mobileMenu.classList.add("opacity-0", "translate-y-[-10px]");
            
            // Update icons
            menuIconOpen.classList.remove("hidden");
            menuIconClose.classList.add("hidden");
            
            // After animation completes
            setTimeout(() => {
                mobileMenuBackdrop.classList.add("pointer-events-none");
                mobileMenu.classList.add("pointer-events-none");
                mobileMenu.classList.remove("is-closing");
                document.body.classList.remove("overflow-hidden");
                isAnimating = false;
            }, 300);
        };

        const openMenu = () => {
            if (isAnimating) return;
            isAnimating = true;
            
            // Enable interaction and start animation
            mobileMenuBackdrop.classList.remove("pointer-events-none");
            mobileMenu.classList.remove("pointer-events-none");
            
            // Trigger reflow for animation
            void mobileMenu.offsetWidth;
            
            // Animate backdrop
            mobileMenuBackdrop.classList.remove("opacity-0");
            mobileMenuBackdrop.classList.add("opacity-100");
            
            // Animate menu container
            mobileMenu.classList.remove("opacity-0", "translate-y-[-10px]");
            mobileMenu.classList.add("opacity-100", "translate-y-0", "is-open");
            
            // Update icons
            menuIconOpen.classList.add("hidden");
            menuIconClose.classList.remove("hidden");
            
            // Lock body scroll
            document.body.classList.add("overflow-hidden");
            
            setTimeout(() => {
                isAnimating = false;
            }, 300);
        };

        menuButton.addEventListener("click", () => {
            const isOpen = mobileMenu.classList.contains("is-open");
            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        // Close menu when clicking on backdrop
        mobileMenuBackdrop.addEventListener("click", closeMenu);

        // Close menu when clicking on links
        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
        
        // Close on escape key
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && mobileMenu.classList.contains("is-open")) {
                closeMenu();
            }
        });
    }
</script>

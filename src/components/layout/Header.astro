---
const { pathname } = Astro.url;
const isOnBlog = pathname === "/blog" || pathname.startsWith("/blog/");
const isOnAbout = pathname === "/about";
---

<header class="fixed top-0 left-0 right-0 z-50 pt-4 px-4">
    <!-- Centered pill navigation container -->
    <nav
        class="group/nav relative mx-auto max-w-4xl flex items-center justify-between h-16 px-6 rounded-full backdrop-blur-xl border border-white/15 bg-gradient-to-b from-white/10 to-white/5 shadow-[0_0_20px_-5px_rgba(139,92,246,0.15),inset_0_1px_0_0_rgba(255,255,255,0.1)]"
    >
        <!-- Glow effect -->
        <div
            class="absolute inset-0 rounded-full bg-gradient-to-r from-violet-500/10 via-purple-500/5 to-pink-500/10 blur-xl opacity-40 -z-10"
        >
        </div>
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
            <svg
                class="h-8 w-8 text-white"
                viewBox="0 0 32 32"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <circle
                    cx="16"
                    cy="16"
                    r="14"
                    stroke="currentColor"
                    stroke-width="2"></circle>
                <circle cx="16" cy="16" r="6" fill="currentColor"></circle>
            </svg>
            <span class="text-lg font-semibold text-white">Lunogram</span>
        </a>

        <!-- Right side: About + Blog link + GitHub icon (Desktop) -->
        <div class="hidden lg:flex items-center gap-6">
            <a
                href="/about"
                class:list={[
                    "text-[15px] font-medium transition-colors",
                    isOnAbout ? "text-white" : "text-white/60 hover:text-white",
                ]}
            >
                About
            </a>
            <a
                href="/blog"
                class:list={[
                    "text-[15px] font-medium transition-colors",
                    isOnBlog ? "text-white" : "text-white/60 hover:text-white",
                ]}
            >
                Blog
            </a>
            <a
                href="https://github.com/lunogram/platform"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 p-2 text-white/70 hover:text-white transition-colors"
                aria-label="View on GitHub"
            >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path
                        fill-rule="evenodd"
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            type="button"
            class="lg:hidden p-2 text-white/60 hover:text-white transition-colors"
            aria-label="Open menu"
            data-mobile-menu-button
        >
            <svg
                class="w-5 h-5 menu-icon-open"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                class="w-5 h-5 menu-icon-close hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu Backdrop -->
    <div
        class="lg:hidden hidden fixed inset-0 top-24 bg-black/60 backdrop-blur-sm z-30"
        data-mobile-menu-backdrop
    >
    </div>

    <!-- Mobile Menu -->
    <div
        class="lg:hidden hidden fixed inset-x-4 top-24 backdrop-blur-xl z-40 rounded-2xl border border-white/15 bg-gradient-to-b from-white/10 to-white/5 shadow-[0_0_20px_-5px_rgba(139,92,246,0.15),inset_0_1px_0_0_rgba(255,255,255,0.1)]"
        data-mobile-menu
    >
        <div class="py-6 px-6 space-y-4">
            <a
                href="/about"
                class="block text-base font-medium text-white/80 hover:text-white transition-colors"
            >
                About
            </a>
            <a
                href="/blog"
                class="block text-base font-medium text-white/80 hover:text-white transition-colors"
            >
                Blog
            </a>
            <div class="pt-4 border-t border-white/10">
                <a
                    href="https://github.com/lunogram/platform"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-white/80 border border-white/10 rounded-full hover:bg-white/5 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                            clip-rule="evenodd"></path>
                    </svg>
                    GitHub
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    const menuButton = document.querySelector("[data-mobile-menu-button]");
    const mobileMenu = document.querySelector("[data-mobile-menu]");
    const mobileMenuBackdrop = document.querySelector(
        "[data-mobile-menu-backdrop]",
    );
    const menuIconOpen = document.querySelector(".menu-icon-open");
    const menuIconClose = document.querySelector(".menu-icon-close");

    if (
        menuButton &&
        mobileMenu &&
        mobileMenuBackdrop &&
        menuIconOpen &&
        menuIconClose
    ) {
        const closeMenu = () => {
            mobileMenu.classList.add("hidden");
            mobileMenuBackdrop.classList.add("hidden");
            menuIconOpen.classList.remove("hidden");
            menuIconClose.classList.add("hidden");
            document.body.classList.remove("overflow-hidden");
        };

        const openMenu = () => {
            mobileMenu.classList.remove("hidden");
            mobileMenuBackdrop.classList.remove("hidden");
            menuIconOpen.classList.add("hidden");
            menuIconClose.classList.remove("hidden");
            document.body.classList.add("overflow-hidden");
        };

        menuButton.addEventListener("click", () => {
            const isOpen = !mobileMenu.classList.contains("hidden");
            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        // Close menu when clicking on backdrop
        mobileMenuBackdrop.addEventListener("click", closeMenu);

        // Close menu when clicking on links
        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    }
</script>

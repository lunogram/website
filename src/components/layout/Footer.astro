---
import { clsx } from "clsx";
import Container from "../ui/Container.astro";

interface Props {
    class?: string;
}

const { class: className } = Astro.props;

const sitemap = {
    company: [
        { name: "About", href: "/about" },
        { name: "Blog", href: "/blog" },
    ],
    resources: [
        { name: "GitHub", href: "https://github.com/lunogram" },
        // { name: "Documentation", href: "/docs" },
    ],
};

const socialLinks = [
    {
        name: "GitHub",
        href: "https://github.com/lunogram",
        icon: "github",
    },
    {
        name: "X (Twitter)",
        href: "https://x.com/lunogram",
        icon: "twitter",
    },
    {
        name: "LinkedIn",
        href: "https://linkedin.com/company/lunogram",
        icon: "linkedin",
    },
];

const currentYear = new Date().getFullYear();
---

<footer class={clsx("relative border-t border-white/5", className)}>
    <!-- CTA Section -->
    <div class="relative py-16 sm:py-24">
        <Container>
            <div class="text-center">
                <p
                    class="font-mono text-xs/5 font-semibold uppercase tracking-widest text-gray-400"
                >
                    Get started
                </p>
                <h2
                    class="mt-6 text-3xl font-medium tracking-tight text-white sm:text-5xl"
                >
                    Ready to automate your<br class="hidden sm:block" />
                    customer communication?
                </h2>
                <p class="mx-auto mt-6 max-w-md text-sm/6 text-gray-400">
                    Start building personalized customer journeys with
                    Lunogram's self-hosted platform.
                </p>
                <div
                    class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row"
                >
                    <a
                        href="https://github.com/lunogram/platform"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex h-10 items-center justify-center gap-2 rounded-full bg-white px-6 text-sm font-medium text-gray-950 shadow-md transition-colors hover:bg-gray-100"
                    >
                        <svg
                            class="h-4 w-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                        Explore on GitHub
                    </a>
                    <a
                        href="https://github.com/lunogram/platform/discussions"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex h-10 items-center justify-center gap-2 rounded-full bg-white/10 px-6 text-sm font-medium text-white ring-1 ring-white/15 transition-colors hover:bg-white/15"
                    >
                        <svg
                            class="h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"
                            ></path>
                        </svg>
                        Start a Discussion
                    </a>
                </div>
            </div>
        </Container>
    </div>

    <!-- Sitemap & Social Links -->
    <div class="border-t border-white/5">
        <Container>
            <div class="py-12">
                <div class="grid grid-cols-2 gap-8 lg:grid-cols-12">
                    <!-- Logo Column -->
                    <div class="col-span-2 lg:col-span-4">
                        <a
                            href="/"
                            class="inline-flex items-center gap-2 text-white"
                        >
                            <svg
                                class="h-8 w-8"
                                viewBox="0 0 32 32"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <circle
                                    cx="16"
                                    cy="16"
                                    r="14"
                                    stroke="currentColor"
                                    stroke-width="2"></circle>
                                <circle
                                    cx="16"
                                    cy="16"
                                    r="6"
                                    fill="currentColor"></circle>
                            </svg>
                            <span class="text-lg font-semibold">Lunogram</span>
                        </a>
                        <p class="mt-4 max-w-xs text-sm/6 text-gray-400">
                            Self-hosted customer communication platform for SaaS
                            companies.
                        </p>
                    </div>

                    <!-- Sitemap Columns -->
                    <div class="lg:col-span-2">
                        <h3 class="text-sm font-medium text-white/50">
                            Company
                        </h3>
                        <ul class="mt-4 space-y-3">
                            {
                                sitemap.company.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="text-sm text-white transition-colors hover:text-white/70"
                                        >
                                            {link.name}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div class="lg:col-span-2">
                        <h3 class="text-sm font-medium text-white/50">
                            Resources
                        </h3>
                        <ul class="mt-4 space-y-3">
                            {
                                sitemap.resources.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="text-sm text-white transition-colors hover:text-white/70"
                                            {...(link.href.startsWith("http")
                                                ? {
                                                      target: "_blank",
                                                      rel: "noopener noreferrer",
                                                  }
                                                : {})}
                                        >
                                            {link.name}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Copyright & Social -->
            <div
                class="flex flex-col items-center justify-between gap-4 border-t border-white/5 py-6 sm:flex-row"
            >
                <p class="text-sm text-gray-400">
                    &copy; {currentYear} Lunogram. All rights reserved.
                </p>
                <span class="flex items-center gap-2 text-sm text-gray-400">
                    <span class="text-lg">🇪🇺</span>
                    Proudly built in the EU
                </span>
                <div class="flex items-center gap-6">
                    <!-- GitHub -->
                    <a
                        href="https://github.com/lunogram"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Visit us on GitHub"
                        class="text-gray-400 transition-colors hover:text-white"
                    >
                        <svg
                            class="h-5 w-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                    </a>
                    <!-- LinkedIn -->
                    <a
                        href="https://www.linkedin.com/company/cloudproud"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Visit us on LinkedIn"
                        class="text-gray-400 transition-colors hover:text-white"
                    >
                        <svg
                            class="h-5 w-5"
                            fill="currentColor"
                            viewBox="0 0 16 16"
                        >
                            <path
                                d="M14.82 0H1.18A1.169 1.169 0 000 1.154v13.694A1.168 1.168 0 001.18 16h13.64A1.17 1.17 0 0016 14.845V1.15A1.171 1.171 0 0014.82 0zM4.744 13.64H2.369V5.996h2.375v7.644zm-1.18-8.684a1.377 1.377 0 11.52-.106 1.377 1.377 0 01-.527.103l.007.003zm10.075 8.683h-2.375V9.921c0-.885-.015-2.025-1.234-2.025-1.218 0-1.425.966-1.425 1.968v3.775H6.233V5.997H8.51v1.05h.032c.317-.601 1.09-1.235 2.246-1.235 2.405-.005 2.851 1.578 2.851 3.63v4.197z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </Container>
    </div>
</footer>

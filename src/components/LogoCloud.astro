---
import { clsx } from 'clsx';
import Container from './ui/Container.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section class={clsx('py-16 border-t border-white/5', className)}>
  <Container>
    <p class="text-center text-sm font-medium text-white/40 mb-8">
      Powered by industry-leading integrations
    </p>
    
    <div class="flex justify-center items-center flex-wrap gap-x-12 gap-y-8 max-sm:gap-x-8">
      <!-- Resend (Email) -->
      <div class="flex items-center gap-2 text-white/50 hover:text-white/70 transition-colors">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.023 0L24 12 2.023 24V0zm2.046 4.324v15.352L18.046 12 4.07 4.324z"/>
        </svg>
        <span class="text-sm font-medium">Resend</span>
      </div>
      
      <!-- Twilio (SMS & Email) -->
      <div class="flex items-center gap-2 text-white/50 hover:text-white/70 transition-colors">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.381 0 0 5.381 0 12s5.381 12 12 12 12-5.381 12-12S18.619 0 12 0zm0 20.571c-4.729 0-8.571-3.842-8.571-8.571S7.271 3.429 12 3.429s8.571 3.842 8.571 8.571-3.842 8.571-8.571 8.571zm-2.857-8.571c0 .944-.771 1.714-1.714 1.714-.944 0-1.714-.77-1.714-1.714 0-.944.77-1.714 1.714-1.714.943 0 1.714.77 1.714 1.714zm8.571 0c0 .944-.77 1.714-1.714 1.714-.943 0-1.714-.77-1.714-1.714 0-.944.771-1.714 1.714-1.714.944 0 1.714.77 1.714 1.714z"/>
        </svg>
        <span class="text-sm font-medium">Twilio</span>
      </div>
      
      <!-- Apple (APNs - Push) -->
      <div class="flex items-center gap-2 text-white/50 hover:text-white/70 transition-colors">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span class="text-sm font-medium">APNs</span>
      </div>
      
      <!-- Google (FCM - Push) -->
      <div class="flex items-center gap-2 text-white/50 hover:text-white/70 transition-colors">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.064 7.51A9.996 9.996 0 0112 2c2.695 0 4.959.99 6.69 2.605l-2.867 2.868C14.786 6.482 13.468 5.977 12 5.977c-2.605 0-4.81 1.76-5.595 4.123-.2.6-.314 1.24-.314 1.9 0 .66.114 1.3.314 1.9.786 2.364 2.99 4.123 5.595 4.123 1.345 0 2.49-.355 3.386-.955a4.6 4.6 0 001.996-3.018H12v-3.868h9.418c.118.654.182 1.336.182 2.045 0 3.046-1.09 5.61-2.982 7.35C16.964 21.105 14.7 22 12 22A9.996 9.996 0 012 12c0-1.614.386-3.14 1.064-4.49z"/>
        </svg>
        <span class="text-sm font-medium">FCM</span>
      </div>
    </div>
  </Container>
</section>

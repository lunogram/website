---
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Heading from '../components/ui/Heading.astro';
import Subheading from '../components/ui/Subheading.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// Get all blog posts, filter out drafts in production, and sort by date
const posts: CollectionEntry<'blog'>[] = (await getCollection('blog'))
  .filter((post: CollectionEntry<'blog'>) => import.meta.env.DEV || !post.data.draft)
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout 
  title="Blog"
  description="Updates, tutorials, and insights from the Lunogram team."
>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-24">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <Subheading class="text-violet-400 mb-6">Blog</Subheading>
        <Heading as="h1" class="text-4xl sm:text-5xl lg:text-6xl">
          Updates & Insights
        </Heading>
        <p class="mt-6 text-lg sm:text-xl text-gray-400 text-balance">
          Stay up to date with the latest from Lunogram.
        </p>
      </div>
    </Container>
  </section>

  <!-- Blog Posts -->
  <section class="py-16 sm:py-24 border-t border-white/5">
    <Container>
      {posts.length === 0 ? (
        <div class="max-w-2xl mx-auto text-center">
          <div class="w-20 h-20 mx-auto mb-8 rounded-2xl bg-violet-500/20 ring-1 ring-violet-500/30 flex items-center justify-center">
            <svg class="w-10 h-10 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-medium tracking-tight text-white mb-4">
            Coming Soon
          </h2>
          <p class="text-lg text-gray-400 mb-8">
            We're working on some great content. In the meantime, follow us on X or star our GitHub repo to stay updated.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a 
              href="https://x.com/lunogram"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-white/10 hover:bg-white/15 rounded-full ring-1 ring-white/10 transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
                <path d="M12.6 0h2.454l-5.36 6.778L16 16h-4.937l-3.867-5.594L2.771 16H.316l5.733-7.25L0 0h5.063l3.495 5.114L12.6 0zm-.86 14.376h1.36L4.323 1.539H2.865l8.875 12.837z"/>
              </svg>
              Follow on X
            </a>
            <a 
              href="https://github.com/lunogram/platform"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-white/10 hover:bg-white/15 rounded-full ring-1 ring-white/10 transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
              Star on GitHub
            </a>
          </div>
        </div>
      ) : (
        <!-- Aligned with navbar inner content (logo left edge to GitHub icon right edge) -->
        <div class="max-w-4xl mx-auto">
          <div class="space-y-12">
            {posts.map((post) => (
              <article class="group">
                <a href={`/blog/${post.id}`} class="block">
                  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                    <time 
                      datetime={post.data.pubDate.toISOString()} 
                      class="text-sm text-gray-500 sm:w-32 sm:flex-shrink-0 sm:pt-1"
                    >
                      {formatDate(post.data.pubDate)}
                    </time>
                    <div class="flex-1">
                      <h2 class="text-xl font-medium text-white group-hover:text-violet-400 transition-colors">
                        {post.data.title}
                      </h2>
                      <p class="mt-2 text-gray-400 line-clamp-2">
                        {post.data.description}
                      </p>
                      {post.data.tags.length > 0 && (
                        <div class="mt-3 flex flex-wrap gap-2">
                          {post.data.tags.map((tag) => (
                            <span class="px-2.5 py-0.5 text-xs font-medium text-gray-400 bg-white/5 rounded-full ring-1 ring-white/10">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      )}
    </Container>
  </section>
</Layout>

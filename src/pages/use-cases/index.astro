---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/ui/Container.astro";
import Heading from "../../components/ui/Heading.astro";
import Subheading from "../../components/ui/Subheading.astro";

const useCases = [
  {
    label: 'Onboarding',
    title: 'Turn signups into active users',
    description: 'Guide new users to their first value moment with targeted welcome sequences across email, push, and in-app messages.',
    href: '/use-cases/onboarding',
    color: 'green',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
  },
  {
    label: 'Retention',
    title: 'Keep your best customers engaged',
    description: 'Detect disengagement before it becomes churn. Automate re-activation campaigns based on behavioral signals.',
    href: '/use-cases/retention',
    color: 'violet',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992"/></svg>`,
  },
  {
    label: 'Re-engagement',
    title: 'Win back dormant users',
    description: 'Reach churned or inactive users with personalized win-back campaigns timed to when they\'re most likely to return.',
    href: '/use-cases/re-engagement',
    color: 'rose',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
  },
];

const colorClasses = {
  green: {
    iconBg: 'bg-green-500/15',
    iconText: 'text-green-400',
    ring: 'ring-green-500/20',
    hoverRing: 'hover:ring-green-500/30',
  },
  violet: {
    iconBg: 'bg-violet-500/15',
    iconText: 'text-violet-400',
    ring: 'ring-violet-500/20',
    hoverRing: 'hover:ring-violet-500/30',
  },
  rose: {
    iconBg: 'bg-rose-500/15',
    iconText: 'text-rose-400',
    ring: 'ring-rose-500/20',
    hoverRing: 'hover:ring-rose-500/30',
  },
} as const;
---

<Layout
  title="Use Cases - Lunogram"
  description="See how Lunogram helps SaaS teams onboard new users, retain customers, and win back churned accounts across every channel."
>
  <!-- Hero -->
  <section class="pt-32 pb-16 sm:pt-40 sm:pb-24">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <Subheading class="text-violet-400 mb-4">Use Cases</Subheading>
        <Heading as="h1" class="text-4xl sm:text-5xl lg:text-6xl">
          Engage customers across<br class="hidden sm:block" />
          their entire lifecycle
        </Heading>
        <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">
          From first signup to long-term loyalty. See how teams use Lunogram to automate the right message at the right moment on the right channel.
        </p>
      </div>
    </Container>
  </section>

  <!-- Use Case Cards -->
  <section class="pb-24">
    <Container>
      <div class="grid gap-6 max-w-5xl mx-auto">
        {useCases.map((useCase) => {
          const colors = colorClasses[useCase.color as keyof typeof colorClasses];
          return (
            <a
              href={useCase.href}
              class:list={[
                "group bg-white/[0.03] rounded-2xl p-8 ring-1 ring-white/10 transition-all flex items-start gap-6",
                colors.hoverRing,
                "hover:bg-white/[0.05]",
              ]}
            >
              <div class:list={[
                "w-14 h-14 rounded-xl flex items-center justify-center shrink-0",
                colors.iconBg,
                `ring-1 ${colors.ring}`,
              ]}>
                <span class={colors.iconText} set:html={useCase.icon} />
              </div>
              <div class="flex-1 min-w-0">
                <p class:list={["font-mono text-xs font-semibold uppercase tracking-widest mb-2", colors.iconText]}>
                  {useCase.label}
                </p>
                <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-white/90">
                  {useCase.title}
                </h2>
                <p class="text-sm text-white/60 leading-relaxed">
                  {useCase.description}
                </p>
              </div>
              <svg class="w-5 h-5 text-white/30 group-hover:text-white/60 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          );
        })}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-white/5">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-medium tracking-tight text-white mb-6">
          Ready to engage your customers?
        </h2>
        <p class="text-gray-400 mb-8">
          Get started with Lunogram Cloud in minutes, or self-host for full control.
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://accounts.lunogram.com"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-gradient-to-r from-violet-600 to-purple-600 px-6 text-sm font-medium text-white shadow-lg shadow-violet-500/25 hover:from-violet-500 hover:to-purple-500 transition-all duration-200"
          >
            Get Started
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="https://github.com/lunogram/platform"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-white/10 px-6 text-sm font-medium text-white ring-1 ring-white/15 transition-colors hover:bg-white/15"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </Container>
  </section>
</Layout>

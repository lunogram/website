---
import Layout from "../layouts/Layout.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
---

<Layout
    title="About"
    description="Learn about Lunogram's mission to simplify customer engagement with self-hosted automation."
>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-16 sm:pt-40 sm:pb-24">
        <Container>
            <div class="max-w-3xl mx-auto text-center">
                <p
                    class="font-mono text-xs font-semibold tracking-widest text-violet-400 uppercase mb-6"
                >
                    About Lunogram
                </p>
                <h1
                    class="text-4xl sm:text-5xl lg:text-6xl font-medium tracking-tight text-white text-balance"
                >
                    Building the future of customer communication
                </h1>
                <p class="mt-6 text-lg sm:text-xl text-gray-400 text-balance">
                    Transparent, self-hosted, and community-driven.
                </p>
            </div>
        </Container>
    </section>

    <!-- Mission Statement -->
    <section class="py-16 sm:py-24 border-t border-white/5">
        <Container>
            <div class="max-w-3xl mx-auto">
                <h2
                    class="text-2xl sm:text-3xl font-medium tracking-tight text-white mb-8"
                >
                    Our Mission
                </h2>
                <div class="space-y-6 text-gray-400 text-lg leading-relaxed">
                    <p>
                        We believe every company should have access to powerful
                        marketing automation tools without being locked into
                        expensive proprietary platforms.
                    </p>
                    <p>
                        Lunogram exists to democratize customer communication.
                        Too many businesses are forced to choose between
                        overpaying for bloated enterprise solutions or cobbling
                        together fragmented tools that don't work well together.
                    </p>
                    <p>
                        Our vision is a world where SaaS companies of any size
                        can engage their customers through email, SMS, push
                        notifications, and webhooks—all from a single, open
                        platform they can trust, customize, and own.
                    </p>
                </div>
            </div>
        </Container>
    </section>

    <!-- Team Section -->
    <section class="py-16 sm:py-24 border-t border-white/5">
        <Container>
            <div class="max-w-3xl mx-auto text-center">
                <p
                    class="font-mono text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4"
                >
                    The Team
                </p>
                <h2
                    class="text-3xl sm:text-4xl font-medium tracking-tight text-white mb-6"
                >
                    Built by a passionate community
                </h2>
                <p class="text-lg text-gray-400 mb-8">
                    Lunogram is developed and maintained by a growing community
                    of contributors who believe in transparent software and
                    accessible marketing automation.
                </p>
                <div class="flex flex-wrap items-center justify-center gap-4">
                    <a
                        href="https://github.com/lunogram/platform/graphs/contributors"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white/80 hover:text-white bg-white/5 hover:bg-white/10 rounded-lg ring-1 ring-white/10 transition-all"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                                clip-rule="evenodd"></path>
                        </svg>
                        View Contributors
                    </a>
                    <a
                        href="https://github.com/lunogram/platform/blob/main/CONTRIBUTING.md"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white/80 hover:text-white bg-white/5 hover:bg-white/10 rounded-lg ring-1 ring-white/10 transition-all"
                    >
                        Become a Contributor
                    </a>
                </div>
            </div>
        </Container>
    </section>

    <!-- Origin Story -->
    <section class="py-16 sm:py-24 border-t border-white/5">
        <Container>
            <div class="max-w-3xl mx-auto">
                <p
                    class="font-mono text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4"
                >
                    Our Story
                </p>
                <h2
                    class="text-2xl sm:text-3xl font-medium tracking-tight text-white mb-8"
                >
                    Built on strong foundations
                </h2>
                <div class="space-y-6 text-gray-400 text-lg leading-relaxed">
                    <p>
                        Lunogram is a continuation of <a
                            href="https://github.com/parcelvoy/platform"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-violet-400 hover:text-violet-300 transition-colors"
                            >Parcelvoy</a
                        >, a marketing automation platform that was archived
                        after years of development.
                    </p>
                    <p>
                        We saw the potential in what Parcelvoy had built—a solid
                        foundation for multi-channel customer communication and
                        made the decision to fork and continue its development.
                        Rather than let this valuable work fade away, we're
                        committed to evolving it into a modern, maintainable
                        platform.
                    </p>
                    <p>
                        Our goal is to honor the original vision while
                        modernizing the codebase, improving the developer
                        experience, and building a sustainable community around
                        the project. We're not starting from scratch; we're
                        building on proven technology with fresh energy and a
                        long-term commitment.
                    </p>
                </div>
            </div>
        </Container>
    </section>
</Layout>
